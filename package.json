{
  "name": "spry-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "src",
    "example/web"
  ],
  "scripts": {
    "build": "make all",
    "web": "make all && bun run example/web/server.ts",
    "native": "make all && d=$PWD && mkdir -p \"$d/example/db\" && cd .build/store/$(uname -m)-linux-gnu/gtk && ./app \"$d/example/ui/tree.json\" \"$d/example/ui/endpoints.json\" \"$d/example/db/demo.db\"",
    "smoke": "make all && .build/store/test/native-smoke .build/store/test/runtime.wasm example/ui/tree.json example/ui/endpoints.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
