{
  "name": "spry-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "src",
    "example/web"
  ],
  "scripts": {
    "build": "make all",
    "web": "make all && bun run example/web/server.ts",
    "native": "make all && ./store/gtk/app .build/store/web/example/runtime.wasm example/ui/tree.json",
    "smoke": "make all && .build/store/test/native-smoke .build/store/web/example/runtime.wasm example/ui/tree.json",
    "test:yyjson": "make all && .build/store/test/yyjson-smoke && bun run tools/run-yyjson-wasm.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
