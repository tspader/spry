{
  "name": "spry-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "src",
    "example/web"
  ],
  "scripts": {
    "build": "make all",
    "web": "make all && bun run example/web/server.tsx",
    "native": "make all && .build/store/$(uname -m)-linux-gnu/gtk/app example/ui/tree.json example/ui/endpoints.json",
    "smoke": "make all && .build/store/test/native-smoke .build/store/test/runtime.wasm example/ui/tree.json example/ui/endpoints.json && .build/store/test/rpc-smoke example/ui/endpoints.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "spry": "workspace:*"
  }
}
