@@ -2176,16 +2190,26 @@ static_inline void *mem_align_up(void *mem, usize align) {
  * This is a simple libc memory allocator wrapper.
  *============================================================================*/
 
+#ifndef YYJSON_DEFAULT_MALLOC
+#define YYJSON_DEFAULT_MALLOC(ctx, size) malloc(size)
+#endif
+#ifndef YYJSON_DEFAULT_REALLOC
+#define YYJSON_DEFAULT_REALLOC(ctx, ptr, old_size, size) realloc(ptr, size)
+#endif
+#ifndef YYJSON_DEFAULT_FREE
+#define YYJSON_DEFAULT_FREE(ctx, ptr) free(ptr)
+#endif
+
 static void *default_malloc(void *ctx, usize size) {
-    return malloc(size);
+    return YYJSON_DEFAULT_MALLOC(ctx, size);
 }
 
 static void *default_realloc(void *ctx, void *ptr, usize old_size, usize size) {
-    return realloc(ptr, size);
+    return YYJSON_DEFAULT_REALLOC(ctx, ptr, old_size, size);
 }
 
 static void default_free(void *ctx, void *ptr) {
-    free(ptr);
+    YYJSON_DEFAULT_FREE(ctx, ptr);
 }
 
