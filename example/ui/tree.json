{
  "kind": "box",
  "props": { "direction": "column", "gap": 16, "padding": 24, "align": "stretch" },
  "children": [
    {
      "kind": "box",
      "props": { "direction": "row", "gap": 12, "align": "center", "justify": "between" },
      "children": [
        { "kind": "text", "props": { "text": "spry sqlite browser" } },
        {
          "kind": "button",
          "props": { "text": "Refresh tables" },
          "on": { "action": "invoke", "event": "click", "handler": "tables", "onResponse": "patch", "target": "tables" }
        }
      ]
    },
    {
      "kind": "box",
      "props": { "direction": "row", "gap": 24, "align": "start" },
      "children": [
        {
          "kind": "box",
          "id": "tables",
          "props": { "direction": "column", "gap": 6 },
          "children": [
            { "kind": "text", "props": { "text": "(refresh to load tables)" } }
          ]
        },
        {
          "kind": "box",
          "props": { "direction": "column", "gap": 12 },
          "children": [
            {
              "kind": "box",
              "id": "grid",
              "props": { "direction": "column", "gap": 4 },
              "children": [
                { "kind": "text", "props": { "text": "(select a table)" } }
              ]
            },
            { "kind": "box", "id": "editor", "props": { "direction": "column", "gap": 8 } }
          ]
        }
      ]
    },
    {
      "kind": "box",
      "props": { "direction": "column", "gap": 8 },
      "children": [
        {
          "kind": "box",
          "props": { "direction": "row", "gap": 8, "align": "center" },
          "children": [
            { "kind": "input", "props": { "name": "sql", "placeholder": "select * from albums" } },
            {
              "kind": "button",
              "props": { "text": "Run" },
              "on": { "action": "invoke", "event": "click", "handler": "exec", "onResponse": "patch", "target": "sql-out" }
            }
          ]
        },
        { "kind": "box", "id": "sql-out", "props": { "direction": "column", "gap": 4 } }
      ]
    }
  ]
}
